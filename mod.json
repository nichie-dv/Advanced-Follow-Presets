{
	"geode": "5.3.0",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "nichie.advanced-follow-presets",
	"name": "Advanced Follow Presets",
	"version": "v0.3.0",
	"developer": "nichie",
	"links": {
		"homepage": "https://nichie.dev",
		"source": "https://github.com/nichie-dv/Advanced-Follow-Presets"
	},
	"description": "Overhauls the advanced follow premade settings",
	"dependencies": {
		"geode.node-ids": ">=1.21.1"
	},
	"settings": {
		"filepaths": {
			"type": "title",
            "name": "Filepath Settings"
		},
		"presets-path": {
			"type": "folder",
			"name": "Presets",
			"description": "Folder path for presets.",
    		"default": "{mod_save_dir}/presets"
		},	
		"template-path": {
			"type": "folder",
			"name": "Templates",
			"description": "Folder path for template presets.",
    		"default": "{mod_save_dir}/templates"
		},
		"extra": {
			"type": "title",
            "name": "Extra Settings"
		},
		"wokemode": {
			"type": "bool",
			"name": "Wokemode",
			"description": "Enables the transgender flag button",
			"default": false
		},
		"confirm-use": {
			"type": "bool",
			"name": "Confirm use popup",
			"description": "Displays a popup before using a preset warning the user.",
			"default": true
		},
		"file-extension": {
			"type": "string",
			"name": "File Extension",
			"description": "Changes the preset file extension (json base).",
			"default": "json",
			"filter": "abcdefghijklmnopqrstuvwxyz"
		}
	}
}
